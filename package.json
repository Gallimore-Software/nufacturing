{
  "name": "nufacturing",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "prepare": "npx husky install",
    "start": "ng serve",
    "build": "ng build",
    "clean": "npm cache clean --force && rm -rf node_modules package-lock.json && npm install",
    "watch": "ng build --watch --configuration development",
    "test": "jest --config jest.config.cjs --coverage --testPathIgnorePatterns='src/.*\\.pact\\.test\\.ts'",
    "test:coverage": "jest --config jest.config.cjs --coverage --maxWorkers=10",
    "cypress:run": "npx cypress run",
    "cypress:open": "npx cypress open",
    "cypress:run:record": "npx cypress run --record",
    "cypress:open:component": "npx cypress open-ct",
    "cypress:run:component": "npx cypress run-ct",
    "pact": "npx jest --config jest.config.cjs --testPathPattern='src/.*\\.pact\\.test\\.ts'",
    "lint": "npx eslint src",
    "lint:fix": "npx eslint src --fix",
    "prettier": "npx prettier --write 'src/**/*.{ts,tsx,js,json,css,scss,md}'",
    "prettier:fix": "npx prettier --write 'src/**/*.{ts,tsx,js,json,css,scss,md}'",
    "ci:clean": "npm clean",
    "ci:install": "npm ci",
    "ci:lint": "npm run lint",
    "ci:prettier": "npm run prettier",
    "ci:test": "npm test --coverage",
    "ci:pact": "npm run pact",
    "ci:build": "npm run build",
    "ci:deploy": "npm run deploy",
    "ci": "npm run ci:clean ci:install && npm run ci:lint && npm run ci:prettier && npm run ci:test && npm run ci:pact && npm run ci:build"
  },
  "private": true,
  "dependencies": {
    "@ag-grid-community/angular": "^32.3.1",
    "@ag-grid-community/client-side-row-model": "^32.3.1",
    "@ag-grid-community/core": "^32.3.1",
    "@ag-grid-community/styles": "latest",
    "@ag-grid-enterprise/excel-export": "latest",
    "@ag-grid-enterprise/master-detail": "latest",
    "@ag-grid-enterprise/multi-filter": "latest",
    "@ag-grid-enterprise/set-filter": "latest",
    "@angular/animations": "^18.2.9",
    "@angular/cdk": "^18.2.10",
    "@angular/common": "^18.2.9",
    "@angular/compiler": "^18.2.9",
    "@angular/core": "^18.2.9",
    "@angular/flex-layout": "^15.0.0-beta.42",
    "@angular/forms": "^18.2.9",
    "@angular/material": "^18.2.10",
    "@angular/platform-browser": "^18.2.9",
    "@angular/platform-browser-dynamic": "^18.2.9",
    "@angular/router": "^18.2.9",
    "@apollo/client": "^3.11.8",
    "@auth0/angular-jwt": "^5.2.0",
    "@testing-library/angular": "^14.5.1",
    "ag-grid-angular": "^32.3.1",
    "ag-grid-community": "^32.3.1",
    "apollo-angular": "^7.2.1",
    "chart.js": "^4.4.3",
    "esbuild": "^0.23.1",
    "graphql": "^16.9.0",
    "graphql-tag": "^2.12.6",
    "jest-extended": "^4.0.2",
    "jest-fetch-mock": "^3.0.3",
    "nufacturing": "file:",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.0",
    "zone.js": "^0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.10",
    "@angular/cli": "^18.2.10",
    "@angular/compiler-cli": "^18.2.9",
    "@eslint/js": "^9.13.0",
    "@pact-foundation/pact": "^13.1.4",
    "@testing-library/jest-dom": "^6.4.8",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "cypress": "^13.13.2",
    "eslint": "^9.13.0",
    "express": "^4.21.1",
    "fs": "^0.0.1-security",
    "http": "^0.0.1-security",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "jest-preset-angular": "^14.2.4",
    "jest-watch-typeahead": "^2.2.2",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.4.5"
  },
  "engines": {
    "node": "20.x"
  }
}
